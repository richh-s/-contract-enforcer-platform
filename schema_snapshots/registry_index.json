{
  "week3-document-refinery-extractions": {
    "fields": [],
    "consumers": [
      {
        "consumer_id": "week4-cartographer",
        "description": "Cartographer ingests doc_id as node identity and extracted_facts as node metadata in the lineage graph. Uses confidence as an edge weight for attribution scoring. Any change to the confidence scale (e.g., 0\u20131 \u2192 0\u2013100) silently inflates attribution by 100\u00d7 without any runtime error \u2014 a silent corruption failure mode.\n",
        "fields_consumed": [
          "doc_id",
          "extracted_facts",
          "extraction_model"
        ],
        "breaking_if_changed": [
          "extracted_facts.confidence",
          "doc_id"
        ],
        "enforcement_mode": "ENFORCE"
      },
      {
        "consumer_id": "week5-event-publisher",
        "description": "Event publisher reads confidence to gate DecisionGenerated events. A threshold of confidence > 0.7 becomes always-true when confidence is on the 0\u2013100 scale, bypassing the quality gate entirely.\n",
        "fields_consumed": [
          "doc_id",
          "confidence"
        ],
        "breaking_if_changed": [
          "confidence"
        ],
        "enforcement_mode": "ENFORCE"
      },
      {
        "consumer_id": "contract-enforcer-runner",
        "description": "The validation runner (consumer-side enforcement) reads all fields to evaluate contract compliance. Used in AUDIT mode to detect violations without blocking the pipeline.\n",
        "fields_consumed": [
          "doc_id",
          "extracted_facts",
          "confidence"
        ],
        "breaking_if_changed": [
          "doc_id",
          "extracted_facts.confidence"
        ],
        "enforcement_mode": "AUDIT"
      }
    ],
    "source_file": "/Users/aman/Desktop/projects/10academy/-contract-enforcer-platform/generated_contracts/week3_extractions.yaml"
  },
